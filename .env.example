# Supabase project URL. Safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key. Safe for browser use when Row Level Security is configured.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key. Server-only. Never expose to client code or NEXT_PUBLIC_ vars.
SUPABASE_SERVICE_ROLE_KEY=

# Email for the first/bootstrap Admin account. Used by later Admin bootstrap stories.
BOOTSTRAP_ADMIN_EMAIL=
